{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "none"
        },
        "new_with_braces": true,
        "method_argument_space": {
            "on_multiline": "ensure_fully_multiline"
        },
        "phpdoc_align": {
            "align": "left"
        },
        "single_line_comment_style": {
            "comment_types": [
                "hash"
            ]
        }
    }
}
